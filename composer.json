{
    "name": "stevecopeza/pet",
    "description": "PET (Plan. Execute. Track)",
    "type": "wordpress-plugin",
    "require": {
        "php": "^8.1",
        "php-di/php-di": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "psr/event-dispatcher": "^1.0",
        "phpstan/phpstan": "^2.1",
        "php-stubs/wordpress-stubs": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "Pet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pet\\Tests\\": "tests/"
        }
    },
    "license": "proprietary",
    "scripts": {
        "test": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "test:e2e": "playwright test",
        "analyse": "php -d memory_limit=512M vendor/bin/phpstan analyse",
        "analyse:baseline": "php -d memory_limit=512M vendor/bin/phpstan analyse --generate-baseline"
    }
}
