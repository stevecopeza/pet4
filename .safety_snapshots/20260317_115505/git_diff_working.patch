+  color: #0d6efd;
+  font-weight: 800;
+}
+
+.pd-list {
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+
+.pd-list-item {
+  border: 1px solid #eee;
+  border-radius: 10px;
+  padding: 10px;
+  background: rgba(255,255,255,0.92);
+}
+
