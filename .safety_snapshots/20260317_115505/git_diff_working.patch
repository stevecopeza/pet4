+  padding: 10px;
+  border-radius: 10px;
+  overflow: auto;
+  margin: 0 0 10px 0;
+  font-size: 12px;
+}
+
+.pd-breakdown {
+  display: grid;
+  grid-template-columns: 1fr;
+  gap: 8px;
+  margin: 0 0 10px 0;
+}
+
